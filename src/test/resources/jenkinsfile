pipeline {
    agent any

    tools {
        maven 'MAVEN'     // Name configured in Jenkins
        jdk 'JDK21'        // Name configured in Jenkins
    }

    stages {

        stage('Checkout') {
            steps {
                git 'https://github.com/Sanjana2504/demoworkshop.git'
            }
        }

        stage('Compile') {
            steps {
                sh 'mvn clean compile'
            }
        }

        stage('Test') {
            steps {
                sh 'mvn test'
            }
        }

        stage('Package') {
            steps {
                sh 'mvn package'
            }
        }

        stage('Archive Artifact') {
            steps {
                archiveArtifacts artifacts: 'target/*.jar', fingerprint: true
            }
        }
    }

    post {
        always {
            junit 'target/surefire-reports/*.xml'
        }
        success {
            echo 'Build completed successfully!'
        }
        failure {
            echo 'Build failed.'
        }
    }
}