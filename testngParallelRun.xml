<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Parallel Execution" thread-count="3" parallel="tests">
<listeners>
<listener class-name="com.qa.demoshop.listeners.ListenerClass"></listener>
<listener class-name="com.qa.demoshop.listeners.Transformer"></listener>
</listeners>

<test name="ChromeBrowser">
  <parameter name="browser" value="chrome"></parameter>
    <classes>
      <class name="com.qa.demoshop.tests.RegisterTest"/>
    </classes>
  </test> <!-- Test -->
  
 <test name="FirefoxBrowser">
  <parameter name="browser" value="firefox"></parameter>
    <classes>
      <class name="com.qa.demoshop.tests.RegisterTest"/>
    </classes>
  </test> <!-- Test -->
  
  <test name="edgeBrowser">
  <parameter name="browser" value="edge"></parameter>
    <classes>
      <class name="com.qa.demoshop.tests.RegisterTest"/>
    </classes>
  </test> <!-- Test --> 
</suite> <!-- Suite -->
